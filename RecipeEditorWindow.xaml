<Window x:Class="RecipeManager.RecipeEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recipe" Height="900" Width="820" MinHeight="700" MinWidth="700"
        WindowStartupLocation="CenterOwner" Background="{StaticResource CanvasBrush}">
    <Border Margin="18" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource GardenBorderBrush}"
            BorderThickness="1" CornerRadius="10" Padding="24">
        <DockPanel>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="0,16,0,0" Background="{StaticResource SurfaceBrush}">
                <Button Content="Cancel" Click="Cancel_Click" Background="{StaticResource MintStrongBrush}"
                        Foreground="{StaticResource DarkTextBrush}"/>
                <Button Content="Save recipe" Click="Save_Click" Background="{StaticResource LemonBrush}"
                        Foreground="{StaticResource DarkTextBrush}" Margin="0"/>
            </StackPanel>
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="0,0,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="245"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Recipe details" FontSize="26" FontWeight="Bold" Foreground="{StaticResource HeaderBrush}"/>
                <TextBlock Text="Adjust every part of the recipe before saving." Margin="0,4,0,14"
                           Foreground="{StaticResource MutedBrush}"/>
                <TextBlock Text="Recipe name" Foreground="{StaticResource HeaderBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="TitleBox" FontSize="16"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="155"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Cuisine" Foreground="{StaticResource HeaderBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="CuisineBox"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Cooking time (minutes)" Foreground="{StaticResource HeaderBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="CookingTimeBox"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Servings" Foreground="{StaticResource HeaderBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="ServingsBox"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Margin="0,18,0,0" Padding="16,14" Background="{StaticResource MintBrush}" CornerRadius="7">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="Ingredients" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="Select ingredients and edit their quantity and unit directly in the list."
                                   Margin="0,3,0,0" Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock x:Name="ExternalIngredientsNotice" Visibility="Collapsed" Foreground="#A35A17"
                                   FontSize="11" TextWrapping="Wrap" Margin="0,5,0,0"/>
                    </StackPanel>
                    <Grid Grid.Row="1" Margin="0,11,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="210"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Search ingredients (English or Dutch)" Foreground="{StaticResource HeaderBrush}"
                                       FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="IngredientSearchBox" TextChanged="IngredientSearchBox_TextChanged"
                                     ToolTip="Try mushroom or paddenstoel"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="Examples: mushroom / paddenstoel, chicken / kip"
                                   Margin="14,25,0,0" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                    </Grid>
                    <DataGrid x:Name="IngredientChoicesList" Grid.Row="2" MinHeight="150" AutoGenerateColumns="False"
                              CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderBrush="{StaticResource GardenBorderBrush}" BorderThickness="1" Background="#FFFFFA"
                              RowBackground="#FFFFFA" AlternatingRowBackground="#F2FAED"
                              HorizontalGridLinesBrush="{StaticResource GardenBorderBrush}">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Use" Binding="{Binding IsSelected, Mode=TwoWay}" Width="55"/>
                            <DataGridTextColumn Header="Ingredient" Binding="{Binding Name}" IsReadOnly="True" Width="*"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" IsReadOnly="True" Width="130"/>
                            <DataGridTextColumn Header="Season" Binding="{Binding Season}" IsReadOnly="True" Width="90"/>
                            <DataGridTextColumn Header="Quantity" Binding="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                            <DataGridTextColumn Header="Unit" Binding="{Binding Unit, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Grid Grid.Row="3" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="230"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Tags (comma-separated)" Foreground="{StaticResource HeaderBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TagsBox" ToolTip="For example: quick, family, spicy" Margin="0,0,0,10"/>
                    <TextBlock Text="Recipe URL" Foreground="{StaticResource HeaderBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="UrlBox" ToolTip="For example: https://example.com/recipe"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Picture" Foreground="{StaticResource HeaderBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <Border x:Name="PicturePreviewBorder" Height="105" Margin="0,0,0,8" CornerRadius="7"
                            BorderBrush="{StaticResource GardenBorderBrush}" BorderThickness="1" Visibility="Collapsed">
                        <Image x:Name="PicturePreview" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Choose…" Click="ChoosePicture_Click" Padding="12,8"/>
                        <Button Content="Remove" Click="RemovePicture_Click" Background="{StaticResource PeachBrush}"
                                Foreground="#542619" Padding="12,8" Margin="0"/>
                    </StackPanel>
                    <TextBlock x:Name="PictureStatusText" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="4" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Instructions" Foreground="{StaticResource HeaderBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="InstructionsBox" Height="125" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Kitchen tools (one per line)" Foreground="{StaticResource HeaderBrush}"
                               FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="ToolsBox" Height="125" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
            </Grid>

            <Expander x:Name="PhotoTextReview" Grid.Row="5" Margin="0,16,0,0" Visibility="Collapsed"
                      Header="Other text found in the photo" IsExpanded="True"
                      Foreground="{StaticResource HeaderBrush}" FontWeight="SemiBold">
                <StackPanel Margin="0,9,0,0">
                    <TextBlock Text="Review this OCR transcript for details that were not placed confidently in the fields above. Text that OCR could not read at all can only be checked in the attached picture."
                               TextWrapping="Wrap" FontWeight="Normal" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,7"/>
                    <TextBox x:Name="PhotoTextBox" Height="180" IsReadOnly="True" AcceptsReturn="True"
                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontWeight="Normal"/>
                </StackPanel>
            </Expander>

            </Grid>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
