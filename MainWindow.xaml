<Window x:Class="RecipeManager.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recipe Manager" Height="900" Width="1440" MinHeight="760" MinWidth="1180"
        Icon="Assets/RecipeManager.ico"
        Background="{StaticResource CanvasBrush}" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate x:Key="ProteinIconTemplate">
            <Grid Width="24" Height="24" Margin="0,0,4,0">
                <Canvas x:Name="MeatIcon" Visibility="Collapsed">
                    <Ellipse Width="21" Height="15" Canvas.Left="1" Canvas.Top="4" Fill="#D95757" Stroke="#A8363B" StrokeThickness="1"/>
                    <Ellipse Width="6" Height="5" Canvas.Left="11" Canvas.Top="8" Fill="#FFF1D4"/>
                    <Path Data="M 4,14 C 8,10 11,15 18,9" Stroke="#F6A0A0" StrokeThickness="1.5"/>
                </Canvas>
                <Canvas x:Name="FishIcon" Visibility="Collapsed">
                    <Ellipse Width="17" Height="12" Canvas.Left="5" Canvas.Top="6" Fill="#35A7D8" Stroke="#187BA7" StrokeThickness="1"/>
                    <Path Data="M 6,7 L 0,3 L 0,21 L 6,17 Z" Fill="#258FC2"/>
                    <Ellipse Width="2.7" Height="2.7" Canvas.Left="17" Canvas.Top="9" Fill="White"/>
                </Canvas>
                <Canvas x:Name="ChickenIcon" Visibility="Collapsed">
                    <Rectangle Width="12" Height="4" Canvas.Left="10" Canvas.Top="14" Fill="#F7E2C1" RenderTransformOrigin="0.5,0.5"><Rectangle.RenderTransform><RotateTransform Angle="38"/></Rectangle.RenderTransform></Rectangle>
                    <Ellipse Width="4" Height="4" Canvas.Left="19" Canvas.Top="17" Fill="#F7E2C1"/>
                    <Ellipse Width="16" Height="14" Canvas.Left="1" Canvas.Top="2" Fill="#E9983F" Stroke="#B96628" StrokeThickness="1" RenderTransformOrigin="0.5,0.5"><Ellipse.RenderTransform><RotateTransform Angle="-25"/></Ellipse.RenderTransform></Ellipse>
                    <Ellipse Width="8" Height="5" Canvas.Left="4" Canvas.Top="5" Fill="#F4B662" Opacity="0.85"/>
                </Canvas>
                <Canvas x:Name="VegetableIcon" Visibility="Collapsed">
                    <Rectangle Width="7" Height="11" Canvas.Left="9" Canvas.Top="11" RadiusX="2" Fill="#62A84F"/>
                    <Ellipse Width="12" Height="12" Canvas.Left="1" Canvas.Top="3" Fill="#52A447"/>
                    <Ellipse Width="13" Height="13" Canvas.Left="7" Canvas.Top="1" Fill="#3F963D"/>
                    <Ellipse Width="11" Height="11" Canvas.Left="14" Canvas.Top="5" Fill="#68B554"/>
                </Canvas>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding}" Value="Meat"><Setter TargetName="MeatIcon" Property="Visibility" Value="Visible"/></DataTrigger>
                <DataTrigger Binding="{Binding}" Value="Fish"><Setter TargetName="FishIcon" Property="Visibility" Value="Visible"/></DataTrigger>
                <DataTrigger Binding="{Binding}" Value="Chicken"><Setter TargetName="ChickenIcon" Property="Visibility" Value="Visible"/></DataTrigger>
                <DataTrigger Binding="{Binding}" Value="Vegetable"><Setter TargetName="VegetableIcon" Property="Visibility" Value="Visible"/></DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <Style x:Key="InlineIngredientPickerButtonStyle" TargetType="ToggleButton">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="#FFFFFA"/>
            <Setter Property="BorderBrush" Value="{StaticResource GardenBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource DarkTextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="BoxBorder" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Grid.Column="1" Text="⌄" Foreground="{StaticResource HeaderBrush}"
                                           FontWeight="Bold" FontSize="15"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-3,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BoxBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BoxBorder" Property="Background" Value="{StaticResource MintBrush}"/>
                                <Setter TargetName="BoxBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="24,18"
                BorderBrush="{StaticResource GardenBorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Canvas Width="230" Height="78" HorizontalAlignment="Left" Opacity="0.82" IsHitTestVisible="False">
                    <Path Stroke="#6E945D" StrokeThickness="2.2" Data="M 12,70 C 55,62 72,27 128,12 M 57,56 C 45,35 40,20 34,5 M 85,38 C 108,45 132,40 156,24"/>
                    <Ellipse Width="42" Height="17" Fill="#A7C890" Canvas.Left="27" Canvas.Top="43" RenderTransformOrigin="0.5,0.5"><Ellipse.RenderTransform><RotateTransform Angle="-30"/></Ellipse.RenderTransform></Ellipse>
                    <Ellipse Width="38" Height="16" Fill="#D7E7B2" Canvas.Left="47" Canvas.Top="24" RenderTransformOrigin="0.5,0.5"><Ellipse.RenderTransform><RotateTransform Angle="38"/></Ellipse.RenderTransform></Ellipse>
                    <Ellipse Width="44" Height="18" Fill="#8FB77B" Canvas.Left="75" Canvas.Top="24" RenderTransformOrigin="0.5,0.5"><Ellipse.RenderTransform><RotateTransform Angle="-28"/></Ellipse.RenderTransform></Ellipse>
                    <Ellipse Width="39" Height="16" Fill="#BFD5A0" Canvas.Left="109" Canvas.Top="9" RenderTransformOrigin="0.5,0.5"><Ellipse.RenderTransform><RotateTransform Angle="-18"/></Ellipse.RenderTransform></Ellipse>
                    <Ellipse Width="34" Height="15" Fill="#87AD74" Canvas.Left="121" Canvas.Top="30" RenderTransformOrigin="0.5,0.5"><Ellipse.RenderTransform><RotateTransform Angle="27"/></Ellipse.RenderTransform></Ellipse>
                    <Path Fill="#C88B58" Data="M 4,70 L 54,70 L 47,78 L 11,78 Z"/>
                    <Path Fill="#DFAD7C" Data="M 10,48 L 50,48 L 45,72 L 15,72 Z"/>
                </Canvas>
                <Canvas Width="230" Height="78" HorizontalAlignment="Right" Opacity="0.82" IsHitTestVisible="False">
                    <Canvas.RenderTransform><ScaleTransform ScaleX="-1" CenterX="115"/></Canvas.RenderTransform>
                    <Path Stroke="#6E945D" StrokeThickness="2.2" Data="M 12,70 C 55,62 72,27 128,12 M 57,56 C 45,35 40,20 34,5 M 85,38 C 108,45 132,40 156,24"/>
                    <Ellipse Width="42" Height="17" Fill="#A7C890" Canvas.Left="27" Canvas.Top="43" RenderTransformOrigin="0.5,0.5"><Ellipse.RenderTransform><RotateTransform Angle="-30"/></Ellipse.RenderTransform></Ellipse>
                    <Ellipse Width="38" Height="16" Fill="#D7E7B2" Canvas.Left="47" Canvas.Top="24" RenderTransformOrigin="0.5,0.5"><Ellipse.RenderTransform><RotateTransform Angle="38"/></Ellipse.RenderTransform></Ellipse>
                    <Ellipse Width="44" Height="18" Fill="#8FB77B" Canvas.Left="75" Canvas.Top="24" RenderTransformOrigin="0.5,0.5"><Ellipse.RenderTransform><RotateTransform Angle="-28"/></Ellipse.RenderTransform></Ellipse>
                    <Ellipse Width="39" Height="16" Fill="#BFD5A0" Canvas.Left="109" Canvas.Top="9" RenderTransformOrigin="0.5,0.5"><Ellipse.RenderTransform><RotateTransform Angle="-18"/></Ellipse.RenderTransform></Ellipse>
                    <Ellipse Width="34" Height="15" Fill="#87AD74" Canvas.Left="121" Canvas.Top="30" RenderTransformOrigin="0.5,0.5"><Ellipse.RenderTransform><RotateTransform Angle="27"/></Ellipse.RenderTransform></Ellipse>
                    <Ellipse Width="31" Height="40" Fill="#F6CE55" Canvas.Left="157" Canvas.Top="17"/>
                    <Path Fill="#C88B58" Data="M 4,70 L 54,70 L 47,78 L 11,78 Z"/>
                    <Path Fill="#DFAD7C" Data="M 10,48 L 50,48 L 45,72 L 15,72 Z"/>
                </Canvas>
                <TextBlock Text="Recipe Manager" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontFamily="Georgia" FontSize="34" FontWeight="Bold" Foreground="{StaticResource HeaderBrush}"/>
            </Grid>
        </Border>

        <Canvas Grid.Row="1" Width="145" Height="230" HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="0,8,0,0" Opacity="0.72" IsHitTestVisible="False">
            <Path Stroke="#70945F" StrokeThickness="2" Data="M 28,210 C 24,155 62,108 96,44 M 45,166 C 30,132 18,105 20,70 M 66,124 C 95,112 116,83 126,55"/>
            <Ellipse Width="56" Height="22" Fill="#A5C58E" Canvas.Left="14" Canvas.Top="126" RenderTransformOrigin="0.5,0.5"><Ellipse.RenderTransform><RotateTransform Angle="34"/></Ellipse.RenderTransform></Ellipse>
            <Ellipse Width="52" Height="21" Fill="#D5E5B0" Canvas.Left="39" Canvas.Top="94" RenderTransformOrigin="0.5,0.5"><Ellipse.RenderTransform><RotateTransform Angle="-31"/></Ellipse.RenderTransform></Ellipse>
            <Ellipse Width="58" Height="23" Fill="#89AF76" Canvas.Left="58" Canvas.Top="61" RenderTransformOrigin="0.5,0.5"><Ellipse.RenderTransform><RotateTransform Angle="26"/></Ellipse.RenderTransform></Ellipse>
            <Ellipse Width="47" Height="19" Fill="#B9D39D" Canvas.Left="88" Canvas.Top="34" RenderTransformOrigin="0.5,0.5"><Ellipse.RenderTransform><RotateTransform Angle="-26"/></Ellipse.RenderTransform></Ellipse>
            <Path Fill="#D5A06D" Data="M 7,193 L 70,193 L 62,230 L 16,230 Z"/>
            <Path Fill="#BC774E" Data="M 1,187 L 76,187 L 70,199 L 7,199 Z"/>
        </Canvas>
        <Canvas Grid.Row="1" Width="145" Height="230" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,0,0" Opacity="0.72" IsHitTestVisible="False">
            <Canvas.RenderTransform><ScaleTransform ScaleX="-1" CenterX="72.5"/></Canvas.RenderTransform>
            <Path Stroke="#70945F" StrokeThickness="2" Data="M 28,210 C 24,155 62,108 96,44 M 45,166 C 30,132 18,105 20,70 M 66,124 C 95,112 116,83 126,55"/>
            <Ellipse Width="56" Height="22" Fill="#A5C58E" Canvas.Left="14" Canvas.Top="126" RenderTransformOrigin="0.5,0.5"><Ellipse.RenderTransform><RotateTransform Angle="34"/></Ellipse.RenderTransform></Ellipse>
            <Ellipse Width="52" Height="21" Fill="#D5E5B0" Canvas.Left="39" Canvas.Top="94" RenderTransformOrigin="0.5,0.5"><Ellipse.RenderTransform><RotateTransform Angle="-31"/></Ellipse.RenderTransform></Ellipse>
            <Ellipse Width="58" Height="23" Fill="#89AF76" Canvas.Left="58" Canvas.Top="61" RenderTransformOrigin="0.5,0.5"><Ellipse.RenderTransform><RotateTransform Angle="26"/></Ellipse.RenderTransform></Ellipse>
            <Ellipse Width="47" Height="19" Fill="#B9D39D" Canvas.Left="88" Canvas.Top="34" RenderTransformOrigin="0.5,0.5"><Ellipse.RenderTransform><RotateTransform Angle="-26"/></Ellipse.RenderTransform></Ellipse>
            <Ellipse Width="38" Height="52" Fill="#F6CE55" Canvas.Left="85" Canvas.Top="105"/>
            <Path Fill="#D5A06D" Data="M 7,193 L 70,193 L 62,230 L 16,230 Z"/>
            <Path Fill="#BC774E" Data="M 1,187 L 76,187 L 70,199 L 7,199 Z"/>
        </Canvas>

        <Grid Grid.Row="1" Margin="22,16,22,14" Panel.ZIndex="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="18,14"
                    BorderBrush="{StaticResource GardenBorderBrush}" BorderThickness="1" Margin="95,0,95,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Recipe name" FontWeight="SemiBold" Foreground="{StaticResource HeaderBrush}" Margin="0,0,0,5"/>
                            <Border Background="#FFFFFA" BorderBrush="{StaticResource GardenBorderBrush}" BorderThickness="1"
                                    CornerRadius="9" Height="48">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="44"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="⌕" FontSize="29" Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-5,0,0"/>
                                    <Grid Grid.Column="1">
                                        <TextBox x:Name="RecipeNameSearchBox" TextChanged="RecipeSearchBox_TextChanged"
                                                 ToolTip="Search recipe names in English or Dutch" FontSize="15"
                                                 Background="Transparent" BorderThickness="0" MinHeight="0" Padding="2,0"
                                                 VerticalContentAlignment="Center"/>
                                        <TextBlock Text="Search by recipe name…" Foreground="#8A968B" FontSize="15"
                                                   VerticalAlignment="Center" IsHitTestVisible="False" Margin="2,0,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers><DataTrigger Binding="{Binding Text, ElementName=RecipeNameSearchBox}" Value=""><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Tags" FontWeight="SemiBold" Foreground="{StaticResource HeaderBrush}" Margin="0,0,0,5"/>
                            <Border Background="#FFFFFA" BorderBrush="{StaticResource GardenBorderBrush}" BorderThickness="1"
                                    CornerRadius="9" Height="48">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="44"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="◇" FontSize="25" Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Grid Grid.Column="1">
                                        <TextBox x:Name="TagSearchBox" TextChanged="RecipeSearchBox_TextChanged"
                                                 ToolTip="Search free-form recipe tags" FontSize="15"
                                                 Background="Transparent" BorderThickness="0" MinHeight="0" Padding="2,0"
                                                 VerticalContentAlignment="Center"/>
                                        <TextBlock Text="Search tags…" Foreground="#8A968B" FontSize="15"
                                                   VerticalAlignment="Center" IsHitTestVisible="False" Margin="2,0,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers><DataTrigger Binding="{Binding Text, ElementName=TagSearchBox}" Value=""><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,11,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="145"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="145"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="230"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Seasonal" FontWeight="SemiBold" Foreground="{StaticResource HeaderBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="SeasonalFilterBox" SelectionChanged="FilterSelectionChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Favorite" FontWeight="SemiBold" Foreground="{StaticResource HeaderBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="FavoriteFilterBox" SelectionChanged="FilterSelectionChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Cuisine" FontWeight="SemiBold" Foreground="{StaticResource HeaderBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="CuisineFilterBox" SelectionChanged="FilterSelectionChanged"/>
                        </StackPanel>
                        <Button Grid.Column="6" Content="Clear filters" Click="ClearAllFilters_Click" VerticalAlignment="Bottom"
                                Background="Transparent" Foreground="{StaticResource PrimaryBrush}" Padding="8,7" Margin="0"/>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock x:Name="PantrySelectionSummary" VerticalAlignment="Center" TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" MaxWidth="680" Foreground="{StaticResource PrimaryBrush}"
                                       FontWeight="SemiBold" Margin="0,0,10,0" Visibility="Collapsed"/>
                            <Button x:Name="PantryPopupButton" Content="Ingredients I have  ◀" Click="PantryPopupButton_Click"
                                    Background="{StaticResource MintStrongBrush}" Foreground="{StaticResource DarkTextBrush}"
                                    Padding="12,6" Margin="0"/>
                        </StackPanel>
                        <Popup x:Name="PantryPopup" PlacementTarget="{Binding ElementName=PantryPopupButton}"
                               Placement="Left" HorizontalOffset="-8" StaysOpen="False" AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <Border Width="430" Padding="16" Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1" CornerRadius="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Ingredients I have" FontFamily="Georgia" FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource HeaderBrush}"/>
                                    <TextBlock Grid.Row="1" Text="Search and check everything currently in your pantry."
                                               Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,3,0,10"/>
                                    <TextBox Grid.Row="2" x:Name="PantryLibrarySearchBox" TextChanged="PantryLibrarySearchBox_TextChanged"
                                             ToolTip="Search ingredient names in English or Dutch"/>
                                    <ListBox Grid.Row="3" x:Name="PantryIngredientsList" Height="360" Margin="0,8,0,0"
                                             BorderBrush="{StaticResource GardenBorderBrush}" BorderThickness="1" Background="#FFFFFA">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          Checked="PantryIngredientChanged" Unchecked="PantryIngredientChanged" Padding="7,4"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Grid Grid.Row="4" Margin="0,10,0,0">
                                        <ScrollViewer MaxHeight="90" VerticalScrollBarVisibility="Auto" Margin="0,0,120,0">
                                            <ItemsControl x:Name="SelectedPantryChips">
                                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding Name, StringFormat={}{0} ×}" Click="RemovePantryIngredient_Click"
                                                                Padding="7,3" Margin="0,0,5,5" Background="{StaticResource LemonBrush}"
                                                                Foreground="{StaticResource DarkTextBrush}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                        <Button Content="Clear ingredients" Click="ClearPantry_Click" HorizontalAlignment="Right"
                                                Background="Transparent" Foreground="{StaticResource PrimaryBrush}" Padding="7,4" Margin="0"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Popup>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="440"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="14"
                        BorderBrush="{StaticResource GardenBorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="ListHeading" Text="All recipes" FontSize="19" FontWeight="Bold"
                                   FontFamily="Georgia" Foreground="{StaticResource HeaderBrush}" Margin="2,0,0,11"/>
                        <ListBox x:Name="RecipesList" Grid.Row="1" SelectionChanged="RecipesList_SelectionChanged"
                                 BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch"
                                 ItemContainerStyle="{StaticResource GardenListBoxItemStyle}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="9" Margin="0,0,0,8" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#FFFFFA"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource GardenBorderBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource MintBrush}"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="92"/>
                                                <ColumnDefinition Width="11"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="92" Height="78" CornerRadius="6" ClipToBounds="True" Background="{StaticResource MintBrush}">
                                                <Grid>
                                                    <Image Source="{Binding ImageData, Converter={StaticResource ByteArrayToImageConverter}}" Stretch="UniformToFill"/>
                                                    <ItemsControl ItemsSource="{Binding ProteinKinds}" ItemTemplate="{StaticResource ProteinIconTemplate}"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                        <ItemsControl.Style>
                                                            <Style TargetType="ItemsControl">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ImageData}" Value="{x:Null}"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ItemsControl.Style>
                                                    </ItemsControl>
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <ItemsControl ItemsSource="{Binding ProteinKinds}" ItemTemplate="{StaticResource ProteinIconTemplate}"
                                                                  ToolTip="{Binding ProteinIconsDescription}" VerticalAlignment="Center" Margin="0,0,5,0">
                                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                    </ItemsControl>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15"
                                                               TextTrimming="CharacterEllipsis" Foreground="{StaticResource DarkTextBrush}"/>
                                                </StackPanel>
                                                <ItemsControl ItemsSource="{Binding Tags}" Margin="0,5,0,0">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{StaticResource MintBrush}" CornerRadius="5" Padding="6,2" Margin="0,0,5,3">
                                                                <TextBlock Text="{Binding}" Foreground="{StaticResource PrimaryBrush}" FontSize="10"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            <Button Grid.Column="3" Content="{Binding FavoriteGlyph}" Click="FavoriteFromList_Click"
                                                    Background="Transparent" Foreground="#E0A500" FontSize="22"
                                                    Padding="5,0" Margin="8,0,0,0" ToolTip="Toggle favorite"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="24"
                        BorderBrush="{StaticResource GardenBorderBrush}" BorderThickness="1">
                    <Grid>
                        <TextBlock x:Name="EmptyState" Text="Select a recipe to see its details" Foreground="{StaticResource MutedBrush}"
                                   FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <ScrollViewer x:Name="DetailsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="128"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="DetailImageBorder" Grid.Column="0" Width="128" Height="100" CornerRadius="8"
                                            ClipToBounds="True" Background="{StaticResource MintBrush}">
                                        <Grid>
                                            <Image x:Name="DetailImage" Stretch="UniformToFill"/>
                                            <ItemsControl x:Name="DetailImagePlaceholder" ItemsSource="{Binding ElementName=DetailProteinIcons, Path=ItemsSource}"
                                                          ItemTemplate="{StaticResource ProteinIconTemplate}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <ItemsControl.LayoutTransform><ScaleTransform ScaleX="1.8" ScaleY="1.8"/></ItemsControl.LayoutTransform>
                                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                    <StackPanel x:Name="DetailReadHeader" Grid.Column="2" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <ItemsControl x:Name="DetailProteinIcons" ItemTemplate="{StaticResource ProteinIconTemplate}"
                                                          Margin="0,0,7,0" VerticalAlignment="Center">
                                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                            </ItemsControl>
                                            <TextBlock x:Name="DetailTitle" FontSize="24" FontWeight="Bold"
                                                       FontFamily="Georgia" Foreground="{StaticResource HeaderBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <TextBlock x:Name="DetailCuisine" Foreground="{StaticResource MutedBrush}" Margin="0,3,0,0" FontSize="13"/>
                                        <ItemsControl x:Name="DetailTagsItems" Margin="0,5,0,0" Visibility="Collapsed">
                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{StaticResource MintBrush}" CornerRadius="6" Padding="7,2" Margin="0,0,5,3">
                                                        <TextBlock Text="{Binding}" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" FontSize="11"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="Servings" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Button Content="−" Click="DecreaseServings_Click" Padding="8,2" Background="{StaticResource MintStrongBrush}" Foreground="{StaticResource DarkTextBrush}"/>
                                            <TextBlock x:Name="ServingCountText" MinWidth="28" TextAlignment="Center" FontWeight="SemiBold"
                                                       Foreground="{StaticResource DarkTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Button Content="+" Click="IncreaseServings_Click" Padding="8,2" Background="{StaticResource MintStrongBrush}" Foreground="{StaticResource DarkTextBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel x:Name="InlineEditHeader" Grid.Column="2" VerticalAlignment="Center" Visibility="Collapsed">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.35*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="0.8*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="1.1*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Recipe name" FontWeight="SemiBold" Foreground="{StaticResource HeaderBrush}" Margin="0,0,0,3"/>
                                                <TextBox x:Name="InlineTitleBox" FontSize="16" FontWeight="SemiBold" MinHeight="34" Padding="8,5"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Cuisine" FontWeight="SemiBold" Foreground="{StaticResource HeaderBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="InlineCuisineBox" MinHeight="34" Padding="8,5"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="Tags" FontWeight="SemiBold" Foreground="{StaticResource HeaderBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="InlineTagsBox" ToolTip="Separate tags with commas" MinHeight="34" Padding="8,5"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="94"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Servings" FontWeight="SemiBold" Foreground="{StaticResource HeaderBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="InlineServingsBox" MinHeight="34" Padding="8,5"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Recipe website" FontWeight="SemiBold" Foreground="{StaticResource HeaderBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="InlineSourceUrlBox" MinHeight="34" Padding="8,5"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                                                <Button x:Name="SaveInlineEditButton" Content="Save" Click="SaveInlineEdit_Click"
                                                        Background="{StaticResource LemonBrush}" Foreground="{StaticResource DarkTextBrush}"
                                                        Visibility="Collapsed" Padding="11,6" Margin="0,0,6,0"/>
                                                <Button x:Name="CancelInlineEditButton" Content="Cancel" Click="CancelInlineEdit_Click"
                                                        Background="{StaticResource MintStrongBrush}" Foreground="{StaticResource DarkTextBrush}"
                                                        Visibility="Collapsed" Padding="11,6" Margin="0"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                        <Button x:Name="FavoriteButton" Click="Favorite_Click" Background="Transparent" Foreground="#E0A500"
                                                FontSize="22" Padding="6,2" ToolTip="Toggle favorite" Margin="0,0,6,0"/>
                                        <Button x:Name="EditButton" Content="Edit" Click="Edit_Click" Background="{StaticResource MintStrongBrush}"
                                                Foreground="{StaticResource DarkTextBrush}" IsEnabled="False" Padding="11,6" Margin="0,0,6,0"/>
                                        <Button x:Name="DeleteButton" Content="Delete" Click="Delete_Click" Background="{StaticResource PeachBrush}"
                                                Foreground="#542619" Padding="11,6" Margin="0" IsEnabled="False"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel x:Name="DetailActionButtons" Orientation="Horizontal" Margin="0,14,0,0">
                                    <Button Content="Share recipe code" Click="ShareRecipeCode_Click" Background="{StaticResource LemonBrush}" Foreground="{StaticResource DarkTextBrush}"/>
                                    <Button Content="Copy missing ingredients" Click="CopyMissingIngredients_Click"/>
                                    <Button x:Name="OpenUrlButton" Content="Open recipe website ↗" Click="OpenUrl_Click" Visibility="Collapsed"/>
                                </StackPanel>
                                <Separator Margin="0,18" Background="{StaticResource LemonBrush}"/>
                                <Grid x:Name="DetailReadSections">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.05*"/><ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="0.85*"/><ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="1.35*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Ingredients" FontFamily="Georgia" FontSize="18" FontWeight="Bold" Margin="0,0,0,9" Foreground="{StaticResource PrimaryBrush}"/>
                                        <StackPanel x:Name="DetailIngredientsPanel"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Kitchen tools" FontFamily="Georgia" FontSize="18" FontWeight="Bold" Margin="0,0,0,9" Foreground="{StaticResource PrimaryBrush}"/>
                                        <TextBlock x:Name="DetailTools" TextWrapping="Wrap" LineHeight="24"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Instructions" FontFamily="Georgia" FontSize="18" FontWeight="Bold" Margin="0,0,0,9" Foreground="{StaticResource PrimaryBrush}"/>
                                        <TextBlock x:Name="DetailInstructions" TextWrapping="Wrap" LineHeight="24"/>
                                    </StackPanel>
                                </Grid>
                                <Grid x:Name="InlineEditSections" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*"/><ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="0.8*"/><ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="1.2*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Ingredients" FontFamily="Georgia" FontSize="18" FontWeight="Bold" Margin="0,0,0,9" Foreground="{StaticResource PrimaryBrush}"/>
                                        <TextBlock Text="Compact list so long recipes do not take over the screen." Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,7"/>
                                        <DataGrid x:Name="InlineIngredientsGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                                                  HeadersVisibility="Column" GridLinesVisibility="None" RowHeaderWidth="0"
                                                  Height="285" Background="#FFFFFA" BorderBrush="{StaticResource GardenBorderBrush}"
                                                  BorderThickness="1" AlternatingRowBackground="{StaticResource MintBrush}"
                                                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                  ScrollViewer.CanContentScroll="False"
                                                  ScrollViewer.PanningMode="None">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Qty" Binding="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged}" Width="65"/>
                                                <DataGridTextColumn Header="Unit" Binding="{Binding Unit, UpdateSourceTrigger=PropertyChanged}" Width="75"/>
                                                <DataGridTemplateColumn Header="Ingredient" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Grid>
                                                                <ToggleButton x:Name="IngredientPickerButton"
                                                                              IsChecked="{Binding IsPickerOpen, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                              Style="{StaticResource InlineIngredientPickerButtonStyle}">
                                                                    <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                                                                </ToggleButton>
                                                                <Popup IsOpen="{Binding IsPickerOpen, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                       PlacementTarget="{Binding ElementName=IngredientPickerButton}"
                                                                       Placement="Bottom"
                                                                       StaysOpen="False"
                                                                       AllowsTransparency="True"
                                                                       PopupAnimation="Fade">
                                                                    <Border Background="{StaticResource SurfaceBrush}"
                                                                            BorderBrush="{StaticResource PrimaryBrush}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="8"
                                                                            Padding="3"
                                                                            Width="{Binding ActualWidth, ElementName=IngredientPickerButton}"
                                                                            MaxHeight="230">
                                                                        <ListBox ItemsSource="{Binding DataContext.InlineIngredientNames, Source={x:Reference RootWindow}}"
                                                                                 SelectedItem="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                 SelectionChanged="InlineIngredientPicker_SelectionChanged"
                                                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                                                 Background="Transparent"
                                                                                 BorderThickness="0"/>
                                                                    </Border>
                                                                </Popup>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Width="42">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Button Content="×" Click="RemoveInlineIngredient_Click"
                                                                    Background="Transparent" Foreground="{StaticResource PeachBrush}"
                                                                    FontSize="16" FontWeight="Bold" Padding="4,0" Margin="0"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <Button Content="+ Add ingredient" Click="AddInlineIngredient_Click"
                                                Background="{StaticResource MintStrongBrush}" Foreground="{StaticResource DarkTextBrush}"
                                                HorizontalAlignment="Left" Padding="10,5" Margin="0,8,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Kitchen tools" FontFamily="Georgia" FontSize="18" FontWeight="Bold" Margin="0,0,0,9" Foreground="{StaticResource PrimaryBrush}"/>
                                        <TextBox x:Name="InlineToolsBox" AcceptsReturn="True" TextWrapping="Wrap" Height="285"
                                                 VerticalScrollBarVisibility="Auto" ToolTip="One tool per line"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Instructions" FontFamily="Georgia" FontSize="18" FontWeight="Bold" Margin="0,0,0,9" Foreground="{StaticResource PrimaryBrush}"/>
                                        <TextBox x:Name="InlineInstructionsBox" AcceptsReturn="True" TextWrapping="Wrap" Height="333"
                                                 VerticalScrollBarVisibility="Auto"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource GardenBorderBrush}"
                BorderThickness="0,1,0,0" Padding="22,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Foreground="{StaticResource MutedBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="＋ Add recipe" Click="Add_Click" Background="{StaticResource LemonBrush}"
                            Foreground="{StaticResource DarkTextBrush}" Padding="12,5"/>
                    <Button Content="Import photo" Click="ImportPhoto_Click" Background="{StaticResource MintStrongBrush}"
                            Foreground="{StaticResource DarkTextBrush}" Padding="12,5"/>
                    <Button Content="Import code" Click="ImportRecipeCode_Click" Background="{StaticResource MintStrongBrush}"
                            Foreground="{StaticResource DarkTextBrush}" Padding="12,5"/>
                    <Button Content="Export database" Click="BackupRecipes_Click" Background="{StaticResource MintStrongBrush}"
                            Foreground="{StaticResource DarkTextBrush}" Padding="12,5" Margin="0"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Ingredients" Click="ManageIngredients_Click" Background="Transparent" Foreground="{StaticResource PrimaryBrush}" Padding="4,1" Margin="0,0,12,0" FontSize="12"/>
                    <Button Content="Restore backup" Click="RestoreRecipes_Click" Background="Transparent" Foreground="{StaticResource PrimaryBrush}" Padding="4,1" Margin="0,0,14,0" FontSize="12"/>
                    <Button Content="What's new" Click="WhatsNew_Click" Background="Transparent" Foreground="{StaticResource MutedBrush}" Padding="4,1" Margin="0,0,14,0" FontSize="12"/>
                    <TextBlock x:Name="VersionText" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <TextBlock x:Name="CurrentSeasonText" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <Button x:Name="UpdateButton" Content="Check for updates" Click="CheckUpdates_Click"
                            Background="Transparent" Foreground="{StaticResource PrimaryBrush}" Padding="4,1" Margin="0" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="CopyToast" Grid.RowSpan="3" Panel.ZIndex="20" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="24" Background="{StaticResource HeaderBrush}" CornerRadius="8" Padding="16,10" Visibility="Collapsed">
            <TextBlock x:Name="CopyToastText" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
        </Border>

        <Border x:Name="PhotoImportProgressOverlay" Grid.RowSpan="3" Panel.ZIndex="30"
                Background="#8A173B25" Visibility="Collapsed">
            <Border Width="430" Padding="28,24" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource GardenBorderBrush}"
                    BorderThickness="1" CornerRadius="14">
                <StackPanel>
                    <TextBlock Text="Reading your recipe photo…" FontFamily="Georgia" FontSize="22"
                               FontWeight="Bold" Foreground="{StaticResource HeaderBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Rotating the image and recognizing its text locally. This can take about half a minute."
                               TextWrapping="Wrap" TextAlignment="Center" Foreground="{StaticResource MutedBrush}"
                               Margin="0,10,0,17"/>
                    <ProgressBar Height="10" IsIndeterminate="True" Foreground="{StaticResource PrimaryBrush}"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
