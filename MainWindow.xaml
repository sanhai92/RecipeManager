<Window x:Class="RecipeManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recipe Manager" Height="760" Width="1180" MinHeight="620" MinWidth="900"
        Background="{StaticResource CanvasBrush}" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}" Padding="24,18" BorderBrush="#174F26" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="My Recipe Book" FontSize="26" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Cook something good with what you have" Foreground="{StaticResource LemonBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Import code" Click="ImportRecipeCode_Click" Background="{StaticResource MintStrongBrush}" Foreground="{StaticResource DarkTextBrush}"/>
                    <Button Content="Manage ingredients" Click="ManageIngredients_Click" Background="{StaticResource MintStrongBrush}" Foreground="{StaticResource DarkTextBrush}"/>
                    <Button Content="＋ Add recipe" Click="Add_Click" Background="{StaticResource LemonBrush}" Foreground="{StaticResource DarkTextBrush}"/>
                    <Button x:Name="EditButton" Content="Edit" Click="Edit_Click" Background="{StaticResource MintStrongBrush}" Foreground="{StaticResource DarkTextBrush}" IsEnabled="False"/>
                    <Button x:Name="DeleteButton" Content="Delete" Click="Delete_Click" Background="{StaticResource PeachBrush}" Foreground="#542619" Margin="0" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="{StaticResource MintBrush}" CornerRadius="10" Padding="14" Margin="0,0,0,14"
                        BorderBrush="{StaticResource MintStrongBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Ingredients I have" FontWeight="Bold" Foreground="{StaticResource HeaderBrush}"/>
                        <TextBlock Text="Search the library, then check what you have." FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,8"/>
                        <TextBox x:Name="PantryLibrarySearchBox" TextChanged="PantryLibrarySearchBox_TextChanged"
                                 ToolTip="Filter the ingredient library" Margin="0,0,0,6"/>
                        <ListBox x:Name="PantryIngredientsList" Height="105" BorderBrush="{StaticResource GardenBorderBrush}"
                                 BorderThickness="1" Background="#FFFFFA" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Checked="PantryIngredientChanged" Unchecked="PantryIngredientChanged" Padding="5,2"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Button Content="Clear ingredients" Click="ClearPantry_Click" HorizontalAlignment="Left"
                                Background="Transparent" Foreground="{StaticResource PrimaryBrush}" Padding="0,7" Margin="0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <CheckBox x:Name="FavoritesOnlyBox" Content="Favorites only" Checked="SearchChanged" Unchecked="SearchChanged"/>
                            <CheckBox x:Name="SeasonalOnlyBox" Content="In season" Margin="18,0,0,0"
                                      Checked="SearchChanged" Unchecked="SearchChanged"
                                      ToolTip="Recipes containing at least one ingredient from the current season"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <StackPanel Grid.Row="1" Margin="0,0,0,9">
                    <TextBlock Text="Find by recipe name" FontWeight="SemiBold" Foreground="{StaticResource HeaderBrush}" Margin="2,0,0,5"/>
                    <TextBox x:Name="RecipeNameSearchBox" TextChanged="RecipeNameSearchBox_TextChanged"
                             ToolTip="Type part of a recipe name; small spelling mistakes are allowed" Margin="0,0,0,9"/>
                    <TextBlock x:Name="ListHeading" Text="All recipes" FontSize="17" FontWeight="Bold" Margin="2,0,0,0" Foreground="{StaticResource DarkTextBrush}"/>
                </StackPanel>
                <ListBox x:Name="RecipesList" Grid.Row="2" SelectionChanged="RecipesList_SelectionChanged"
                         BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource GardenBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8" Width="330">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15"
                                               TextTrimming="CharacterEllipsis" Foreground="{StaticResource DarkTextBrush}"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="{Binding FavoriteGlyph}" Click="FavoriteFromList_Click"
                                            Background="Transparent" Foreground="#E0A500" FontSize="22"
                                            Padding="5,0" Margin="8,0,0,0" ToolTip="Toggle favorite"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="28" BorderBrush="{StaticResource GardenBorderBrush}" BorderThickness="1">
                <Grid>
                    <TextBlock x:Name="EmptyState" Text="Select a recipe to see its details" Foreground="{StaticResource MutedBrush}"
                               FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <ScrollViewer x:Name="DetailsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border x:Name="DetailImageBorder" Height="230" CornerRadius="8" ClipToBounds="True" Background="{StaticResource MintBrush}" Margin="0,0,0,20" Visibility="Collapsed">
                                <Image x:Name="DetailImage" Stretch="UniformToFill"/>
                            </Border>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="DetailTitle" FontSize="28" FontWeight="Bold" Foreground="{StaticResource HeaderBrush}" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="DetailCuisine" Foreground="{StaticResource MutedBrush}" Margin="0,5,0,0" FontSize="14"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,9,0,0">
                                        <TextBlock Text="Servings" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <Button Content="−" Click="DecreaseServings_Click" Padding="8,2" Background="{StaticResource MintStrongBrush}"
                                                Foreground="{StaticResource DarkTextBrush}" ToolTip="Decrease displayed servings"/>
                                        <TextBlock x:Name="ServingCountText" MinWidth="28" TextAlignment="Center" FontWeight="SemiBold"
                                                   Foreground="{StaticResource DarkTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <Button Content="+" Click="IncreaseServings_Click" Padding="8,2" Background="{StaticResource MintStrongBrush}"
                                                Foreground="{StaticResource DarkTextBrush}" ToolTip="Increase displayed servings"/>
                                    </StackPanel>
                                </StackPanel>
                                <Button x:Name="FavoriteButton" Grid.Column="1" Click="Favorite_Click" Background="Transparent" Foreground="#E0A500"
                                        FontSize="28" Padding="8,1" Margin="12,0,0,0" ToolTip="Toggle favorite"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                <Button Content="Share recipe code" Click="ShareRecipeCode_Click" Background="{StaticResource LemonBrush}" Foreground="{StaticResource DarkTextBrush}"/>
                                <Button Content="Copy missing ingredients" Click="CopyMissingIngredients_Click"/>
                                <Button x:Name="OpenUrlButton" Content="Open recipe website ↗" Click="OpenUrl_Click"
                                        Visibility="Collapsed"/>
                            </StackPanel>
                            <Separator Margin="0,20" Background="{StaticResource LemonBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Ingredients" FontSize="18" FontWeight="Bold" Margin="0,0,0,9" Foreground="{StaticResource PrimaryBrush}"/>
                                    <StackPanel x:Name="DetailIngredientsPanel"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Kitchen tools" FontSize="18" FontWeight="Bold" Margin="0,0,0,9" Foreground="{StaticResource PrimaryBrush}"/>
                                    <TextBlock x:Name="DetailTools" TextWrapping="Wrap" LineHeight="24"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Instructions" FontSize="18" FontWeight="Bold" Margin="0,25,0,9" Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock x:Name="DetailInstructions" TextWrapping="Wrap" LineHeight="24"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource MintBrush}" BorderBrush="{StaticResource MintStrongBrush}" BorderThickness="0,1,0,0" Padding="24,8">
            <Grid>
                <TextBlock x:Name="StatusText" Foreground="{StaticResource MutedBrush}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Back up recipes" Click="BackupRecipes_Click" ToolTip="Create a safe copy of all recipes and pictures"
                            Background="Transparent" Foreground="{StaticResource PrimaryBrush}" Padding="4,1" Margin="0,0,12,0" FontSize="12"/>
                    <Button Content="Restore backup" Click="RestoreRecipes_Click" ToolTip="Restore recipes from a previous backup"
                            Background="Transparent" Foreground="{StaticResource PrimaryBrush}" Padding="4,1" Margin="0,0,14,0" FontSize="12"/>
                    <Button Content="What's new" Click="WhatsNew_Click" ToolTip="See changes in this version"
                            Background="Transparent" Foreground="{StaticResource MutedBrush}" Padding="4,1" Margin="0,0,14,0" FontSize="12"/>
                    <TextBlock x:Name="VersionText" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <TextBlock x:Name="CurrentSeasonText" Foreground="{StaticResource MutedBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,14,0"
                               ToolTip="Current meteorological season based on your computer's date"/>
                    <Button x:Name="UpdateButton" Content="Check for updates" Click="CheckUpdates_Click"
                            Background="Transparent" Foreground="{StaticResource PrimaryBrush}" Padding="4,1" Margin="0" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="CopyToast" Grid.RowSpan="3" Panel.ZIndex="20"
                HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="24"
                Background="{StaticResource HeaderBrush}" CornerRadius="8" Padding="16,10"
                Visibility="Collapsed">
            <TextBlock x:Name="CopyToastText" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
        </Border>
    </Grid>
</Window>
