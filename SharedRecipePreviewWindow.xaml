<Window x:Class="RecipeManager.SharedRecipePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preview shared recipe" Height="700" Width="700" MinHeight="580" MinWidth="580"
        Background="{StaticResource CanvasBrush}" WindowStartupLocation="CenterOwner">
    <Border Margin="18" Padding="24" Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource GardenBorderBrush}" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock x:Name="RecipeTitleText" FontSize="26" FontWeight="Bold" Foreground="{StaticResource HeaderBrush}" TextWrapping="Wrap"/>
                <TextBlock x:Name="RecipeSummaryText" Margin="0,5,0,0" Foreground="{StaticResource MutedBrush}"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,20,0,8">
                <TextBlock Text="Ingredients" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="Only new ingredients you select will be added to your ingredient library."
                           Margin="0,3,0,0" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
            </StackPanel>

            <ListBox x:Name="IngredientsList" Grid.Row="2" BorderThickness="0" Background="Transparent"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="9,5" Margin="0,0,0,3" CornerRadius="4" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#FFF4E5"/>
                                    <Setter Property="BorderBrush" Value="#E7B66D"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsKnown}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource MintBrush}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource MintStrongBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding QuantityText}" FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource DarkTextBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource DarkTextBrush}"/>
                                    <TextBlock Text="{Binding StatusText}" Margin="0,1,0,0" FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#A35A17"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsKnown}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding SharedDetailsText}" Visibility="{Binding SharedDetailsVisibility}"
                                               Margin="0,2,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="2" Content="Add to my ingredients" IsChecked="{Binding AddToLibrary, Mode=TwoWay}"
                                          Visibility="{Binding AddControlVisibility}" VerticalAlignment="Center" Margin="16,0,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Row="3" Margin="0,14,0,0" Padding="12" Background="{StaticResource MintBrush}" CornerRadius="7">
                <ScrollViewer MaxHeight="175" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Recipe details" FontSize="15" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="Instructions" Margin="0,9,0,0" FontWeight="SemiBold" Foreground="{StaticResource DarkTextBrush}"/>
                        <TextBlock x:Name="InstructionsText" Margin="0,4,0,0" TextWrapping="Wrap" LineHeight="20"
                                   Foreground="{StaticResource DarkTextBrush}"/>
                        <TextBlock Text="Kitchen tools" Margin="0,10,0,0" FontWeight="SemiBold" Foreground="{StaticResource DarkTextBrush}"/>
                        <TextBlock x:Name="ToolsText" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}"/>
                        <StackPanel x:Name="SourcePanel" Visibility="Collapsed">
                            <TextBlock Text="Source" Margin="0,10,0,0" FontWeight="SemiBold" Foreground="{StaticResource DarkTextBrush}"/>
                            <TextBlock x:Name="SourceText" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancel" Click="Cancel_Click" Background="{StaticResource MintStrongBrush}" Foreground="{StaticResource DarkTextBrush}"/>
                <Button Content="Continue to edit" Click="Import_Click" Background="{StaticResource LemonBrush}" Foreground="{StaticResource DarkTextBrush}" Margin="0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
