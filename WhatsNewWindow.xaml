<Window x:Class="RecipeManager.WhatsNewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="What's new" Height="650" Width="680" MinHeight="500" MinWidth="560"
        Background="{StaticResource CanvasBrush}" WindowStartupLocation="CenterOwner">
    <Border Margin="18" Padding="26" Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource GardenBorderBrush}" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel>
                <TextBlock Text="What's new in Recipe Manager" FontSize="26" FontWeight="Bold" Foreground="{StaticResource HeaderBrush}"/>
                <TextBlock x:Name="VersionSummaryText" Margin="0,6,0,0" FontSize="14" Foreground="{StaticResource MutedBrush}"/>
                <TextBlock Text="Here are the changes that matter to you." Margin="0,4,0,18" Foreground="{StaticResource MutedBrush}"/>
            </StackPanel>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ChangesPanel"/>
            </ScrollViewer>
            <Button Grid.Row="2" Content="Got it" Click="Close_Click" HorizontalAlignment="Right"
                    Margin="0,20,0,0" Background="{StaticResource LemonBrush}" Foreground="{StaticResource DarkTextBrush}"/>
        </Grid>
    </Border>
</Window>
