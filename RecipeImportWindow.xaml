<Window x:Class="RecipeManager.RecipeImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import recipe" Height="520" Width="760" MinHeight="470" MinWidth="680"
        Background="{StaticResource CanvasBrush}" WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Import a recipe" FontSize="25" FontWeight="Bold" Foreground="{StaticResource HeaderBrush}"/>
        <TextBlock Grid.Row="1" Margin="0,6,0,14" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"
                   Text="Paste recipe text or enter a recipe website. The app will convert it into an editable recipe preview before anything is saved."/>

        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource GardenBorderBrush}"
                BorderThickness="1" CornerRadius="12" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Source type" FontWeight="SemiBold" Foreground="{StaticResource HeaderBrush}" Margin="0,0,0,5"/>
                    <ComboBox x:Name="SourceTypeBox" SelectionChanged="SourceTypeBox_SelectionChanged">
                        <ComboBoxItem Content="Website URL"/>
                        <ComboBoxItem Content="Pasted recipe text or sharing code"/>
                    </ComboBox>
                </StackPanel>

                <TextBlock x:Name="HelpText" Grid.Row="1" Margin="0,12,0,12" Foreground="{StaticResource MutedBrush}"
                           TextWrapping="Wrap"/>

                <Grid Grid.Row="2">
                    <Grid x:Name="UrlPanel" Visibility="Visible">
                        <StackPanel>
                            <TextBlock Text="Recipe website" FontWeight="SemiBold" Foreground="{StaticResource HeaderBrush}" Margin="0,0,0,5"/>
                            <TextBox x:Name="UrlBox" ToolTip="https://example.com/my-recipe"/>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="TextPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="TextPanelLabel" Text="Recipe text" FontWeight="SemiBold"
                                   Foreground="{StaticResource HeaderBrush}" Margin="0,0,0,5"/>
                        <TextBox x:Name="TextImportBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" FontSize="13"
                                 ToolTip="Paste recipe text, a chat message, copied website text, or an RM1 sharing code"/>
                    </Grid>
                </Grid>

                <TextBlock x:Name="ErrorText" Grid.Row="3" Margin="0,12,0,0" Foreground="#A53528"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Click="Cancel_Click" Background="{StaticResource MintStrongBrush}"
                    Foreground="{StaticResource DarkTextBrush}"/>
            <Button Content="Preview recipe" Click="Preview_Click" Background="{StaticResource LemonBrush}"
                    Foreground="{StaticResource DarkTextBrush}" Margin="0"/>
        </StackPanel>
    </Grid>
</Window>
