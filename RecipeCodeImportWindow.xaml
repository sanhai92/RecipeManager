<Window x:Class="RecipeManager.RecipeCodeImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import recipe code" Height="360" Width="620" MinHeight="320" MinWidth="520"
        Background="{StaticResource CanvasBrush}" WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Import a shared recipe" FontSize="23" FontWeight="Bold" Foreground="{StaticResource HeaderBrush}"/>
        <TextBlock Grid.Row="1" Margin="0,6,0,14" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"
                   Text="Paste an RM1 sharing code below. You will see the complete recipe in the editor before anything is saved."/>
        <TextBox x:Name="CodeBox" Grid.Row="2" AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="13"
                 ToolTip="Recipe codes begin with RM1:"/>
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <TextBlock x:Name="ErrorText" Foreground="#A53528" VerticalAlignment="Center" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="Cancel_Click" Background="{StaticResource MintStrongBrush}" Foreground="{StaticResource DarkTextBrush}"/>
                <Button Content="Preview recipe" Click="Preview_Click" Background="{StaticResource LemonBrush}" Foreground="{StaticResource DarkTextBrush}" Margin="0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
